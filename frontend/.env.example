# GeneTrust Frontend Environment Variables
# Copy this file to frontend/.env.local and fill in the values.
# frontend/.env.local is gitignored — never commit it.
#
# Vite exposes only VITE_* prefixed variables to the browser.

# ─── Network ──────────────────────────────────────────────────────────────────
# Which Stacks network to connect to: testnet | mainnet
VITE_NETWORK=testnet

# Stacks API node URL
VITE_STACKS_NODE=https://api.testnet.hiro.so

# ─── SDK Toggle ───────────────────────────────────────────────────────────────
# Set to true to use real on-chain contract calls.
# Set to false to use mock data (useful for UI-only development).
VITE_USE_REAL_SDK=false

# ─── Contract Addresses ───────────────────────────────────────────────────────
# Testnet deployer address (from default.testnet-plan.yaml):
#   ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
#
# Mainnet deployer address:
#   SP3KKFRRWQVJXEJCGM6ZB359EF01VRY86HW6CCD45

VITE_DATASET_REGISTRY_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
VITE_DATASET_REGISTRY_NAME=dataset-registry

VITE_EXCHANGE_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
VITE_EXCHANGE_NAME=exchange

VITE_ATTESTATIONS_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
VITE_ATTESTATIONS_NAME=attestations

VITE_DATA_GOVERNANCE_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
VITE_DATA_GOVERNANCE_NAME=data-governance


# ─── App Identity ─────────────────────────────────────────────────────────────
# Override the app name and URL displayed in the wallet connection popup
VITE_APP_NAME=GeneTrust
VITE_APP_URL=https://genetrust.xyz

# ─── Debug ────────────────────────────────────────────────────────────────────
# Set to true to enable verbose contract call logging in the browser console.
VITE_DEBUG=false

# ─── Notes ────────────────────────────────────────────────────────────────────
# Full setup guide: docs/env-setup.md
# Type definitions for all VITE_ variables: frontend/src/vite-env.d.ts
