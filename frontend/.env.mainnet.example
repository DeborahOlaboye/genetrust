# GeneTrust Frontend — Mainnet Environment Variables
# Copy this file to frontend/.env.local when deploying against mainnet contracts.
# Replace addresses with your actual mainnet deployer address if redeploying.

VITE_NETWORK=mainnet
VITE_STACKS_NODE=https://api.hiro.so
VITE_USE_REAL_SDK=true

# Mainnet contract addresses (deployer: SP3KKFRRWQVJXEJCGM6ZB359EF01VRY86HW6CCD45)
VITE_DATASET_REGISTRY_ADDRESS=SP3KKFRRWQVJXEJCGM6ZB359EF01VRY86HW6CCD45
VITE_DATASET_REGISTRY_NAME=dataset-registry

VITE_EXCHANGE_ADDRESS=SP3KKFRRWQVJXEJCGM6ZB359EF01VRY86HW6CCD45
VITE_EXCHANGE_NAME=exchange

VITE_ATTESTATIONS_ADDRESS=SP3KKFRRWQVJXEJCGM6ZB359EF01VRY86HW6CCD45
VITE_ATTESTATIONS_NAME=attestations

VITE_DATA_GOVERNANCE_ADDRESS=SP3KKFRRWQVJXEJCGM6ZB359EF01VRY86HW6CCD45
VITE_DATA_GOVERNANCE_NAME=data-governance

VITE_APP_NAME=GeneTrust
VITE_APP_URL=https://genetrust.xyz

VITE_DEBUG=false
