# GeneTrust Backend / SDK Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# ─── Network ──────────────────────────────────────────────────────────────────
NODE_ENV=development
STACKS_NETWORK=testnet
STACKS_NODE_URL=https://api.testnet.hiro.so

# ─── Contract Addresses ───────────────────────────────────────────────────────
# Testnet: ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
# Mainnet: SP3KKFRRWQVJXEJCGM6ZB359EF01VRY86HW6CCD45

DATASET_REGISTRY_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
DATASET_REGISTRY_NAME=dataset-registry

EXCHANGE_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
EXCHANGE_NAME=exchange

ATTESTATIONS_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
ATTESTATIONS_NAME=attestations

DATA_GOVERNANCE_ADDRESS=ST2VXH7RRKSAYNMWCVVMD972B7HP3H2QY96V8Q161
DATA_GOVERNANCE_NAME=data-governance

# ─── IPFS ─────────────────────────────────────────────────────────────────────
# IPFS gateway or Infura endpoint for pinning encrypted datasets
IPFS_GATEWAY=https://ipfs.io
IPFS_PROJECT_ID=
IPFS_PROJECT_SECRET=

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-GCM encryption key for tiered dataset access
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
