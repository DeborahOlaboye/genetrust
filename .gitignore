
# ─── Stacks / Clarinet credentials ───────────────────────────────────────────
# Deployer mnemonics — never commit these
**/settings/Mainnet.toml
**/settings/Testnet.toml
# Allow example templates
!**/settings/*.toml.example
.cache/**
history.txt

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.info
costs-reports.json

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
.npm/
.pnp.*
.yarn/

# ─── Playwright E2E test artifacts ────────────────────────────────────────────
/playwright-report/
/playwright/.cache/
/test-results/

# ─── Environment files ────────────────────────────────────────────────────────
# Local overrides — contain secrets, never commit
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local
# Allow documented example templates
!.env.example
!frontend/.env.example
!frontend/.env.*.example

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/
frontend/dist/
frontend/build/

# ─── Coverage ─────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
frontend/coverage/

# ─── Vite / Rollup cache ──────────────────────────────────────────────────────
.vite/
frontend/.vite/
*.local
rollup.config.js.cache

# ─── OS generated files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Docker ───────────────────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ─── Interact script results ──────────────────────────────────────────────────
interact-results-*.json

# ─── Clarinet deployment receipts ─────────────────────────────────────────────
# Receipts are generated by clarinet deployments apply and may contain tx IDs
# They are safe to commit but often contain environment-specific data
# Uncomment the line below to ignore them:
# deployments/*-receipts.json

# ─── Python / tooling ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
.venv/
venv/
ENV/
.python-version

# ─── Temporary and scratch files ──────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej
*.patch
*.diff
*~
.scratch/
scratch/

# ─── macOS extended attributes ────────────────────────────────────────────────
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ─── Windows specific ─────────────────────────────────────────────────────────
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# ─── Frontend tooling extras ──────────────────────────────────────────────────
frontend/.next/
frontend/storybook-static/
frontend/.turbo/
frontend/.parcel-cache/
frontend/tsconfig.tsbuildinfo
