
# ─── Stacks / Clarinet credentials ───────────────────────────────────────────
# Deployer mnemonics — never commit these
**/settings/Mainnet.toml
**/settings/Testnet.toml
# Allow example templates
!**/settings/*.toml.example
.cache/**
history.txt

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.info
costs-reports.json

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
.npm/
.pnp.*
.yarn/

# ─── Playwright E2E test artifacts ────────────────────────────────────────────
/playwright-report/
/playwright/.cache/
/test-results/

# ─── Environment files ────────────────────────────────────────────────────────
# Local overrides — contain secrets, never commit
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local
# Allow documented example templates
!.env.example
!frontend/.env.example
!frontend/.env.*.example
